{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and basic profile info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "Represents a conversation history.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "type": "object" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profiles."
    },
    "/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Private chat records."
    }
  }
}
