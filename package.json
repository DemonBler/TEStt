{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && npm run build:server && electron-builder",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=dist-server/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "download-animations": "node download_animations.mjs",
    "start": "node server.ts"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "firebase": "^12.11.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.546.0",
    "node-llama-cpp": "^3.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "vite": "^6.2.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.vaelindra.app",
    "productName": "Vaelindra",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
